# LootLocker – Online-Highscores pro Kurs
# Werte aus dem LootLocker-Dashboard (https://console.lootlocker.com)
# Datei als ".env" kopieren und ausfüllen (wird nicht ins Git eingecheckt)

VITE_LOOTLOCKER_API_KEY=your_game_api_key_here

# Leaderboard-Keys im Code:
# time_drift, serpentinen, sprintstrecke

# Optional – wird auf "0.1.0" gesetzt wenn nicht angegeben
# VITE_LOOTLOCKER_GAME_VERSION=0.1.0
